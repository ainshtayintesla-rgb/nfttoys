# NFT Toys - Environment Variables
# Copy this file to .env and fill in the values

# ===== API Server =====
# API server URL (Express backend)
NEXT_PUBLIC_API_URL=https://api.nfttoys.shop
# Wallet network mode: mainnet | testnet
NEXT_PUBLIC_WALLET_NETWORK=testnet
# Wallet v2 network mode: mainnet | testnet
NEXT_PUBLIC_WALLET_V2_NETWORK=testnet

# ===== Telegram =====
NEXT_PUBLIC_BOT_USERNAME=YourBotUsername
NEXT_PUBLIC_ADMIN_IDS=123456789,987654321
NEXT_PUBLIC_TG_GROUP=nfttoys_chat
NEXT_PUBLIC_TG_CHANNEL=nfttoysuz

# ===== Development =====
NODE_ENV=development

# ===== Security =====
# Used by backend for QR signing and JWT auth
TOKEN_SECRET=your_32_char_minimum_secret_here
