    "test:v2": "tsx --test tests/wallet-v2.integration.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "argon2": "^0.44.0",
    "bip39": "^3.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.6",
    "@types/supertest": "^7.2.0",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
