# Environment variables
PORT=4000
NODE_ENV=development

# Local PostgreSQL
DATABASE_URL=postgresql://nfttoys:nfttoys@127.0.0.1:5432/nfttoys?schema=public

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Security
TOKEN_SECRET=your_32_char_minimum_secret_here
JWT_SECRET=your_32_char_minimum_secret_here
JWT_EXPIRES_IN=30d
WALLET_V2_PEPPER=your_wallet_v2_pepper_here
WALLET_V2_FINGERPRINT_PEPPER=your_wallet_v2_fingerprint_pepper_here
WALLET_V2_ACCESS_TOKEN_SECRET=your_wallet_v2_access_secret_here
WALLET_V2_REFRESH_TOKEN_SECRET=your_wallet_v2_refresh_secret_here
WALLET_V2_ACCESS_TOKEN_TTL_SEC=3600
WALLET_V2_REFRESH_TOKEN_TTL_SEC=2592000
WALLET_V2_CHALLENGE_TTL_SEC=300
# mainnet | testnet; defaults to testnet outside production
WALLET_NETWORK=testnet
# mainnet | testnet; defaults to testnet outside production
WALLET_V2_NETWORK=testnet

# CORS
ALLOWED_ORIGINS=https://nfttoys.shop,https://www.nfttoys.shop,http://localhost:3000

USERBOT_API_URL=http://userbot:8095
USERBOT_INTERNAL_SECRET=change-me-secret

# Optional auth cookie domain for cross-subdomain production sessions
AUTH_COOKIE_DOMAIN=.nfttoys.shop
