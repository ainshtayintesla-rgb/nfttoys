# Global ignore rules for nfttoys monorepo

# Secrets and local env files
.env
.env.*
!.env.example
!.env.*.example
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Python virtual environments and caches
**/.venv/
**/venv/
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/

# Node/JS dependencies and build outputs
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/coverage/
**/.turbo/
**/.cache/
**/*.tsbuildinfo

# Logs and runtime artifacts
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
**/server/data/

# Editor/OS noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Local backup folders
.backup-*/
