# Telegram bot token
TELEGRAM_BOT_TOKEN=

# Shared secret used by server -> bot internal API
BOT_INTERNAL_TOKEN=

# Internal API bind
BOT_HOST=127.0.0.1
BOT_PORT=8090

# Mini app deep link used in inline button
MINI_APP_PROFILE_URL=

# Fallback bot start URL for notification permission flow
BOT_START_URL=

# Language defaults and local storage path
DEFAULT_LANGUAGE=ru
BOT_LANG_STORE=/root/nfttoys/bot/data/user_lang.json

# Notification settings storage
BOT_PREFS_STORE=/root/nfttoys/bot/data/user_prefs.json

# Logging
BOT_LOG_LEVEL=INFO
